# Variables para el trabajo LOCAL con Odoo.
# Copia este archivo a `.env` en la raíz del repo y rellena ODOO_API_KEY:
#     cp docs/odoo-local.env.example .env
# El .env NUNCA se sube a git (está en .gitignore) — la API key es secreta.

# Odoo (bpo-dici) — 3 ya están, solo falta la API key
ODOO_URL=https://bpo-dici.odoo.com
ODOO_DB=bpo-dici
ODOO_USERNAME=hola.dici.sas@gmail.com
ODOO_API_KEY=

# Empresa del hotel (base MULTIEMPRESA): los clientes que cree la integración se
# asignan a esta empresa. Empresas permitidas del usuario de integración:
#   1 = DICI S.A.S. (empresa por defecto del usuario)
#   3 = RIVO S.A.S.
#   4 = GRUPO PINAO S EN C A
#   5 = MIRADA S.A.S  ← el hotel (NIT 902032515-0)
# Para verlos en Odoo → Contactos hay que tener "MIRADA S.A.S" seleccionada en el
# selector de empresa (arriba a la derecha). Si se deja vacío, quedan compartidos.
ODOO_COMPANY_ID=5

# Opcional
ODOO_TIMEOUT_MS=15000
