# OTASync / Kunas PMS
OTASYNC_TOKEN=           # Auth token (optional; system will auto-login if username/password are set)
OTASYNC_USERNAME=        # PMS login username
OTASYNC_PASSWORD=        # PMS login password
OTASYNC_PROPERTY_ID=9889 # Property ID (default 9889 for Hotel Estar)
OTASYNC_USE_CHANNEL=false
OTASYNC_CHANNEL_ID=      # Optional Kunas channel ID; only used when OTASYNC_USE_CHANNEL=true
OTASYNC_CHANNEL_NAME=Private reservation

# Active payment provider
PAYMENT_PROVIDER=wompi

# Wompi Payment Gateway
WOMPI_PUBLIC_KEY=       # Public key from the active Wompi merchant account
WOMPI_INTEGRITY_SECRET= # Integrity secret from Wompi dashboard; server-side only
WOMPI_WEBHOOK_SECRET=   # Webhook events secret from the active Wompi dashboard

# Mercado Pago Checkout Pro rollback
# PAYMENT_PROVIDER=mercadopago
# MERCADOPAGO_PUBLIC_KEY=
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_WEBHOOK_SECRET=
# MERCADOPAGO_SUCCESS_URL=https://estar.com.co/reservar.html?payment=success
# MERCADOPAGO_FAILURE_URL=https://estar.com.co/reservar.html?payment=failure
# MERCADOPAGO_PENDING_URL=https://estar.com.co/reservar.html?payment=pending

# Email (Resend)
RESEND_API_KEY=          # API key from resend.com — required to send booking confirmation emails

# Server / CORS
ALLOWED_ORIGIN=http://localhost:8888 # Allowed CORS origin; set to your production domain in Netlify (e.g. https://estar.com.co)
PROXY_URL=               # Optional URL for the scraping proxy used by get-booking-rating to fetch the Booking.com review score
