# OTASync / Kunas PMS
OTASYNC_TOKEN=           # Auth token (optional; system will auto-login if username/password are set)
OTASYNC_USERNAME=        # PMS login username
OTASYNC_PASSWORD=        # PMS login password
OTASYNC_PROPERTY_ID=9889 # Property ID (default 9889 for Hotel Estar)
OTASYNC_USE_CHANNEL=false
OTASYNC_CHANNEL_ID=      # Optional Kunas channel ID; only used when OTASYNC_USE_CHANNEL=true
OTASYNC_CHANNEL_NAME=Private reservation

# Active payment provider
PAYMENT_PROVIDER=wompi

# Wompi Payment Gateway
WOMPI_PUBLIC_KEY=       # Public key from the active Wompi merchant account
WOMPI_INTEGRITY_SECRET= # Integrity secret from Wompi dashboard; server-side only
WOMPI_WEBHOOK_SECRET=   # Webhook events secret from the active Wompi dashboard

# Mercado Pago Checkout Pro rollback
# PAYMENT_PROVIDER=mercadopago
# MERCADOPAGO_PUBLIC_KEY=
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_WEBHOOK_SECRET=
# MERCADOPAGO_SUCCESS_URL=https://estar.com.co/reservar.html?payment=success
# MERCADOPAGO_FAILURE_URL=https://estar.com.co/reservar.html?payment=failure
# MERCADOPAGO_PENDING_URL=https://estar.com.co/reservar.html?payment=pending

# Email (Resend)
RESEND_API_KEY=          # API key from resend.com — required to send booking confirmation emails

# Server / CORS
ALLOWED_ORIGIN=http://localhost:8888 # Allowed CORS origin; set to your production domain in Netlify (e.g. https://estar.com.co)
PROXY_URL=               # Optional URL for the scraping proxy used by get-booking-rating to fetch the Booking.com review score

# Guest app access and document validation
GUEST_APP_TOKEN_SECRET=  # Long random secret used to sign temporary guest sessions
GUEST_APP_DATA_ENCRYPTION_KEY= # Long random secret used to encrypt guest records in Blobs
GUEST_APP_DEMO_MODE=false
GUEST_APP_STORE_DOCUMENTS=false # Keep false unless temporary ID storage is approved

# Azure AI Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT= # Example: https://your-resource.cognitiveservices.azure.com
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID=prebuilt-idDocument
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30

# Integration webhooks
GUEST_APP_SYNC_WEBHOOK_URL=https://estar.com.co/api/guest-sync
GUEST_APP_SYNC_WEBHOOK_SECRET=
GUEST_APP_DRIVE_WEBHOOK_URL=https://estar.com.co/api/guest-drive
GUEST_APP_DRIVE_WEBHOOK_SECRET=
GOOGLE_DRIVE_APPS_SCRIPT_URL=     # Web app URL ending in /exec
GOOGLE_DRIVE_APPS_SCRIPT_SECRET=  # Must match the Apps Script WEBHOOK_SECRET property

# Optional online payment link for additional services
GUEST_SERVICE_PAYMENT_MODE=room_charge # room_charge or payment_link
GUEST_SERVICE_PAYMENT_URL=

# ── Analytics / Marketing (A-6, auditoría 360°) ──────────────────────────────
# Server-side GA4 conversions via the Measurement Protocol. The browser already
# fires `purchase`; these recover ad-blocked sessions (GA4 dedupes by
# transaction_id). Leave blank to disable server-side tracking.
GA4_MEASUREMENT_ID=        # e.g. G-9PB0Z2KQJK (same property as the on-page tag)
GA4_API_SECRET=            # GA4 Admin > Data Streams > Measurement Protocol API secrets
# Optional ad pixels. When set, build.js injects the pixel (consent-gated via
# Consent Mode v2). Leave blank to keep them out of the build entirely.
META_PIXEL_ID=             # Meta (Facebook/Instagram) pixel id
GOOGLE_ADS_ID=             # Google Ads tag, e.g. AW-XXXXXXXXX

# ── WhatsApp chatbot (Meta Cloud API) — see docs/whatsapp-bot.md ─────────────
WHATSAPP_TOKEN=             # permanent system-user token (Meta Business)
WHATSAPP_PHONE_NUMBER_ID=   # Cloud API phone number id (not the phone number)
WHATSAPP_APP_SECRET=        # Meta app secret; validates X-Hub-Signature-256
WHATSAPP_VERIFY_TOKEN=      # arbitrary string echoed in the webhook handshake
WHATSAPP_GRAPH_VERSION=     # optional, defaults to v25.0
WHATSAPP_BOT_ENABLED=       # 'true' to let the bot answer (kill switch)

# ── WhatsApp bot AI mode (Claude) — see docs/whatsapp-bot.md ─────────────────
ANTHROPIC_API_KEY=          # enables AI conversations; without it the bot uses the menu flows
WHATSAPP_AI_MODEL=          # optional, defaults to claude-haiku-4-5 (claude-opus-4-8 for max quality)
WHATSAPP_AI_EFFORT=         # optional: low (default) | medium | high
WHATSAPP_AI_MAX_TOKENS=     # optional, defaults to 8000
WHATSAPP_AI_TIMEOUT_MS=     # optional, per-request timeout, defaults to 50000

# Guardián de seguridad (doble modelo): clasifica cada mensaje antes del conversacional
WHATSAPP_GUARD_ENABLED=     # 'false' para desactivar (default: activo si hay API key)
WHATSAPP_GUARD_MODEL=       # opcional, default claude-haiku-4-5
WHATSAPP_GUARD_TIMEOUT_MS=  # opcional, default 8000
