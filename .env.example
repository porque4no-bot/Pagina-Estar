# .env.example — plantilla de variables de Hotel Estar (proyecto Netlify: estarmz)
#
# ESTADO de cada variable (revisado 22-jun-2026 contra el .env de producción):
#   ✓ prod    = creada y funcionando en producción (Netlify)
#   ⏳ falta   = aún NO cargada
#   opcional  = no requerida para operar
#   ⚠         = atención (rotar la llave / requerida para una función específica)
#
# IMPORTANTE: aquí NUNCA van los valores reales (este archivo se sube a git).
# Los valores viven solo en Netlify y en el .env local. Las variables NUEVAS se
# agregan en secciones fechadas AL FINAL para que se distingan fácil.

# ── OTASync / Kunas PMS ──────────────────────────────────────────────────────
OTASYNC_TOKEN=            # ✓ prod ⚠ ROTAR (quedó expuesta en chat) · Auth token (auto-login si hay user/pass)
OTASYNC_USERNAME=         # ✓ prod · usuario del PMS
OTASYNC_PASSWORD=         # ✓ prod · clave del PMS
OTASYNC_PROPERTY_ID=9889  # ✓ prod · ID de propiedad (Hotel Estar)
OTASYNC_USE_CHANNEL=false # ✓ prod (en prod =true) · usar canal Kunas
OTASYNC_CHANNEL_ID=       # ✓ prod (=66483) · canal web; usado si USE_CHANNEL=true
OTASYNC_CHANNEL_NAME=Private reservation # opcional · nombre del canal (default mostrado)
OTASYNC_WEBHOOK_SECRET=   # ✓ prod · valida el webhook entrante de OTASync (avail/reserva/cancelación)

# ── Pasarela de pago ACTIVA ──────────────────────────────────────────────────
# El motor y la cotización ofrecen AMBAS (el cliente elige). PAYMENT_PROVIDER es
# el proveedor por defecto/legacy; ambas pasarelas funcionan en paralelo.
PAYMENT_PROVIDER=wompi     # ✓ prod

# ── Wompi ────────────────────────────────────────────────────────────────────
WOMPI_PUBLIC_KEY=         # ✓ prod · llave PÚBLICA (no secreta)
WOMPI_PRIVATE_KEY=        # ✓ prod · llave privada
WOMPI_INTEGRITY_SECRET=   # ✓ prod · secreto de integridad (firma server-side)
WOMPI_WEBHOOK_SECRET=     # ✓ prod · secreto de eventos del webhook

# ── Mercado Pago (ACTIVO junto con Wompi) ────────────────────────────────────
MERCADOPAGO_PUBLIC_KEY=   # ✓ prod · llave PÚBLICA (no secreta)
MERCADOPAGO_ACCESS_TOKEN= # ✓ prod · access token (secreto)
MERCADOPAGO_CLIENT_ID=    # ✓ prod · client id de la app MP
MERCADOPAGO_CLIENT_SECRET=# ✓ prod · client secret de la app MP
MERCADOPAGO_WEBHOOK_SECRET= # ⚙ OPCIONAL (22-jun) · si la pones, valida la firma; si NO, el webhook verifica el pago contra la API de MP (igual de seguro). Ya no bloquea
MERCADOPAGO_SUCCESS_URL=https://estar.com.co/reservar.html?payment=success # ✓ prod
MERCADOPAGO_FAILURE_URL=https://estar.com.co/reservar.html?payment=failure # ✓ prod
MERCADOPAGO_PENDING_URL=https://estar.com.co/reservar.html?payment=pending # ✓ prod
# MERCADOPAGO_CHECKOUT_MODE=  # opcional

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=           # ✓ prod · API key de resend.com (envío de correos)
ADMIN_NOTIFY_EMAIL=       # ✓ prod · destino de avisos al equipo (pedidos, alertas); separados por coma

# ── Servidor / CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:8888 # ✓ prod (=https://estar.com.co) · origen CORS permitido
PROXY_URL=                # ✓ prod · proxy para el rating de Booking.com (get-booking-rating)

# ── Netlify Blobs (persistencia: cotizaciones, reembolsos, IAM, etc.) ────────
BLOBS_TOKEN=              # ✓ prod ⚠ ROTAR (quedó expuesta en chat)
NETLIFY_SITE_ID=          # ✓ prod · site id de Netlify

# ── App de huésped (sesión + cifrado de datos) ───────────────────────────────
GUEST_APP_TOKEN_SECRET=   # ✓ prod · firma de sesiones temporales del huésped
GUEST_APP_DATA_ENCRYPTION_KEY= # ✓ prod · cifra los registros del huésped en Blobs
GUEST_APP_DEMO_MODE=false # ✓ prod (=false)
GUEST_APP_STORE_DOCUMENTS=false # ✓ prod (=false) · no guardar el documento salvo aprobación

# ── Azure AI Document Intelligence (OCR del documento) ───────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT= # ✓ prod
AZURE_DOCUMENT_INTELLIGENCE_KEY=      # ✓ prod
AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID=prebuilt-idDocument # ✓ prod
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30       # ✓ prod

# ── Webhooks de integración + Google Drive ───────────────────────────────────
GUEST_APP_SYNC_WEBHOOK_URL=https://estar.com.co/api/guest-sync   # ✓ prod
GUEST_APP_SYNC_WEBHOOK_SECRET=    # ✓ prod
GUEST_APP_DRIVE_WEBHOOK_URL=https://estar.com.co/api/guest-drive # ✓ prod
GUEST_APP_DRIVE_WEBHOOK_SECRET=   # ✓ prod
GOOGLE_DRIVE_APPS_SCRIPT_URL=     # ✓ prod · web app que termina en /exec
GOOGLE_DRIVE_APPS_SCRIPT_SECRET=  # ✓ prod ⚠ ROTAR (quedó expuesta en chat) · debe coincidir con el WEBHOOK_SECRET del Apps Script
GOOGLE_DRIVE_FOLDER_ID=           # ✓ prod · carpeta destino en Drive
# GOOGLE_SERVICE_ACCOUNT_JSON=    # opcional · credenciales de service account (si no se usa Apps Script)

# ── Pago en línea de servicios adicionales (guest app) ───────────────────────
#   room_charge  → no cobra en línea (solo registra el pedido)
#   payment_link → GUEST_SERVICE_PAYMENT_URL genérico con ?reference&amount
#   wompi        → Wompi Web Checkout firmado; al aprobar, el webhook carga el
#                  folio de la reserva (Fase B). Requiere las llaves de Wompi.
GUEST_SERVICE_PAYMENT_MODE=room_charge # ✓ prod (=room_charge) · room_charge | payment_link | wompi | mercadopago | both  ← MP y 'both' agregados 22-jun
GUEST_SERVICE_PAYMENT_URL=        # ⏳ falta (solo si mode=payment_link)
GUEST_APP_BASE_URL=               # opcional · origen del sitio para el redirect de Wompi (si no, usa la URL de Netlify)

# ── Pedidos del guest app → folio de la reserva (OTASync/Kunas) ──────────────
GUEST_SERVICE_FOLIO_ENABLED=      # ⏳ falta · 'true' para cargar pedidos "a mi cuenta" al folio Kunas (probar con reserva real antes)
OTASYNC_GUEST_SERVICE_EXTRA_ID=   # opcional · id_extras para las líneas del folio
BREAKFAST_UPGRADE_ENABLED=        # ⏳ falta · 'true' para que el comedor pueda AGREGAR desayuno a una reserva sin él (carga folio). OFF por defecto

# ── Carril A: operación / producción (todos OFF por defecto) ─────────────────
ALERT_ENABLED=            # ⏳ falta · kill-switch de alertas (_alert.js); default ON. Inerte sin RESEND_API_KEY
ALERT_EMAIL=             # opcional · destino de alertas (default ADMIN_NOTIFY_EMAIL); ALERT_DEDUPE_TTL_SEC opcional
STAY_EMAILS_ENABLED=     # ⏳ falta · 'true' activa correos pre-llegada/post-estadía (cron). STAY_EMAILS_PRE_DAYS/POST_DAYS, REVIEW_LINK_URL opcionales
GUEST_NOTES_TO_PMS_ENABLED= # ⏳ falta · 'true' para que la nota del huésped llegue a la reserva en OTASync
BACKUP_ENABLED=          # ⏳ falta · 'true' activa el respaldo diario de Blobs. BACKUP_RETENTION_DAYS/INCLUDE_PII/TO_DRIVE/ALWAYS_EMAIL opcionales
REFUND_BANK_FORM_ENABLED= # ⏳ falta · 'true' activa el formulario de cuenta para reembolso manual (A9)
REFUND_LINK_SECRET=      # ⏳ falta · secreto HMAC del enlace de datos bancarios (fallback GUEST_APP_TOKEN_SECRET; obligatorio si se activa A9)
REFUND_GATEWAY_AUTO_ENABLED= # ⏳ falta · 'true' = al APROBAR un reembolso de Mercado Pago se ejecuta solo vía API. OFF por defecto. Wompi NO tiene API (siempre ticket manual)
QUOTE_EXPIRY_REMINDER_ENABLED= # ⏳ falta · 'true' activa el correo "tu cotización vence pronto" (cron)

# ── Paneles de equipo (desayuno + admin) — Google/Firebase + allowlist ───────
FIREBASE_PROJECT_ID=      # ✓ prod · proyecto Firebase que verifica los ID tokens de los paneles
ADMIN_EMAILS=             # ✓ prod · correos con acceso admin (superadmin de respaldo del sistema de roles)
STAFF_EMAILS=             # ⏳ falta (opcional) · correos del personal del comedor (los admin ya entran)

# ── Analytics / Marketing ────────────────────────────────────────────────────
GA4_MEASUREMENT_ID=       # ✓ prod · G-XXXX (misma propiedad que el tag en página)
GA4_API_SECRET=           # ✓ prod · GA4 Admin > Data Streams > Measurement Protocol
META_PIXEL_ID=            # ⏳ falta (opcional) · pixel de Meta; build.js lo inyecta si está
GOOGLE_ADS_ID=            # ⏳ falta (opcional) · tag de Google Ads (AW-...)

# ── WhatsApp chatbot (Meta Cloud API) — pendiente conversación con socios ────
WHATSAPP_TOKEN=           # ⏳ falta · token permanente del system-user
WHATSAPP_PHONE_NUMBER_ID= # ⏳ falta · phone number id de Cloud API
WHATSAPP_APP_SECRET=      # ⏳ falta · app secret de Meta (valida X-Hub-Signature-256)
WHATSAPP_VERIFY_TOKEN=    # ⏳ falta · string del handshake del webhook
WHATSAPP_GRAPH_VERSION=   # opcional · default v25.0
WHATSAPP_BOT_ENABLED=     # ⏳ falta · 'true' para que el bot responda (kill switch)
ANTHROPIC_API_KEY=        # ⏳ falta · activa el modo IA (Claude); sin él, flujos de menú
WHATSAPP_AI_MODEL=        # opcional · default claude-haiku-4-5
WHATSAPP_AI_EFFORT=       # opcional · low (default) | medium | high
WHATSAPP_AI_MAX_TOKENS=   # opcional · default 8000
WHATSAPP_AI_TIMEOUT_MS=   # opcional · default 50000
WHATSAPP_GUARD_ENABLED=   # opcional · 'false' para desactivar el guardián (default activo si hay API key)
WHATSAPP_GUARD_MODEL=     # opcional · default claude-haiku-4-5
WHATSAPP_GUARD_TIMEOUT_MS=# opcional · default 8000

# ── Odoo (ERP/CRM) — maestro de clientes, Fase 1 ─────────────────────────────
ODOO_URL=                 # ✓ prod · https://...odoo.com (sin slash final)
ODOO_DB=                  # ✓ prod · nombre de la base
ODOO_USERNAME=            # ✓ prod · usuario de integración (email)
ODOO_API_KEY=             # ✓ prod · API key del usuario
ODOO_COMPANY_ID=          # ✓ prod (=5, Mirada) · empresa del hotel (multiempresa)
ODOO_TIMEOUT_MS=          # opcional · default 10000


# ═══════════════════════════════════════════════════════════════════════════
# ▼▼▼ NUEVO · 22-jun-2026 · del build en paralelo (TTLock + Mercado Pago guest) ▼▼▼
# ═══════════════════════════════════════════════════════════════════════════

# ── TTLock (chapas) — códigos temporales por reserva ─────────────────────────
# Módulo _ttlock.js LISTO y mock-safe. Para emitir códigos reales: pon
# TTLOCK_ENABLED=true y carga las credenciales de TU cuenta de desarrollador
# TTLock (open.ttlock.com) — NO las de la integración con Kunas (esas son de OTASync).
TTLOCK_ENABLED=           # ⏳ falta · 'true' activa la emisión de códigos (default OFF/mock)
TTLOCK_CLIENT_ID=         # ⏳ falta · clientId de tu app TTLock  ← LO LLENAS TÚ
TTLOCK_CLIENT_SECRET=     # ⏳ falta · clientSecret de tu app TTLock  ← LO LLENAS TÚ
TTLOCK_USERNAME=          # ⏳ falta · usuario de tu cuenta TTLock  ← LO LLENAS TÚ
TTLOCK_PASSWORD_MD5=      # ⏳ falta · clave de la cuenta TTLock en MD5  ← LO LLENAS TÚ
TTLOCK_LOCKS_JSON=        # ⏳ falta · mapeo apto→lockId, ej. {"101":123,...,"305":140,"main":999} (lockId desde /v3/lock/list o la app)
TTLOCK_API_BASE=          # opcional · default global (api.sciener.com); si tu cuenta es UE → https://euapi.ttlock.com
TTLOCK_TIMEOUT_MS=        # opcional · default 10000
TTLOCK_PASSCODE_TYPE=     # opcional · tipo de passcode (default 3 = período, válido toda la estadía)

# ── Mercado Pago — ruta directa resiliente (Sprint 2, Mesa Redonda C4/C5) ────
# Iguala la ruta directa de MP a Wompi: lock anti-doble-reserva + idempotencia por
# estadía + reintentos (insertReservation) + "pago cobrado sin reserva" recuperable
# (recordPending) que el cron de reconciliación detecta. La reconciliación de MP se
# enciende sola si cobras con MP (PAYMENT_PROVIDER=mercadopago) o si hay token MP.
# MP es la ruta de ROLLBACK (hoy activo = Wompi) → seguro de dejar apagado.
# También gestionable desde /admin → Configuración. ⚠️ Probar en sandbox MP antes.
MP_DIRECT_RESILIENT_ENABLED=  # ⏳ falta · 'true' activa el andamiaje de resiliencia en la ruta directa de Mercado Pago (default OFF)

# ── Mercado Pago en el guest app (pedidos/upgrades en línea) ─────────────────
# El cobro en línea del guest app ahora soporta MP además de Wompi. Se activa
# poniendo GUEST_SERVICE_PAYMENT_MODE=mercadopago (o 'both'). Reusa
# MERCADOPAGO_ACCESS_TOKEN + MERCADOPAGO_WEBHOOK_SECRET (ver arriba).
MERCADOPAGO_CHECKOUT_MODE= # opcional · 'sandbox'/'test' usa el init_point de pruebas (probar antes de producción)

# ── Motor de códigos de descuento (camino Wompi) ─────────────────────────────
# Motor listo y APAGADO. Los códigos se crean en /admin → pestaña "Códigos".
# Validación y firma del monto con descuento son server-side. Probar UNA reserva
# real con código en sandbox Wompi antes de encender en producción.
DISCOUNT_CODES_ENABLED=   # ⏳ falta · 'true' muestra el campo de código en el motor y activa el descuento (default OFF)

# Nota (22-jun): en Odoo se crearon 6 campos x_estar_* en res.partner
# (canal, ultimo_checkout, noches_total, presupuesto, motivo_viaje, perfil).
# Se llenan solos desde la web; NO requieren variable de entorno.

# ── Odoo Fase 3 (NPS) + Fase 4 (Helpdesk/PQR) ───────────────────────────────
# Apps Surveys + Helpdesk YA instaladas. Encuesta NPS creada (id 1). Equipo de
# PQR de Mirada = id 3. Toggles también gestionables desde /admin → Configuración.
HELPDESK_ENABLED=   # ⏳ falta · 'true' = solicitudes/cancelaciones del huésped abren ticket en Odoo Helpdesk (default OFF)
HELPDESK_TEAM_ID=   # opcional · equipo de Helpdesk (default 3 = 'Atención al cliente' de Mirada)
NPS_ENABLED=        # ⏳ falta · 'true' = el correo post-estadía incluye el enlace a la encuesta NPS (default OFF; requiere STAY_EMAILS_ENABLED para que el correo salga)
NPS_SURVEY_URL=     # opcional · URL pública de la encuesta (default ya apunta a la encuesta creada)

# ── Bóveda de cifrado de PII — rotación de claves (Mesa Redonda, 22-jun) ──────
# El cifrado de datos de huésped ahora es REVERSIBLE y con clave versionada
# (_crypto-vault.js). NO HACE FALTA TOCAR NADA: sigue usando el
# GUEST_APP_DATA_ENCRYPTION_KEY que ya tienes cargado (se lee como clave 'k1').
# Estas DOS son OPCIONALES y solo se necesitan EL DÍA QUE ROTES la clave:
GUEST_APP_KEY_RING=        # opcional · JSON {"k1":"<secreto-viejo>","k2":"<secreto-nuevo>"} para tener varias claves a la vez durante una rotación (SECRETO → solo Netlify, NUNCA un valor aquí)
GUEST_APP_ACTIVE_KEY_ID=   # opcional · con cuál clave se ESCRIBE hoy (ej. 'k2'); las viejas siguen leyéndose. Default: la primera del anillo / 'k1'

# ── Sprint 1: cerrar el lazo de cancelación en OTASync (Mesa Redonda C3) ──────
# Al aprobar/denegar una cancelación en /admin → Reembolsos, la reserva se marca
# como CANCELADA en OTASync (libera el inventario; soft-cancel, preserva el
# registro). Sin esto, la reserva sigue ocupando el cuarto hasta cancelarla a mano.
# También gestionable desde /admin → Configuración. ⚠️ Probar con una reserva real
# antes de encender.
OTASYNC_AUTO_CANCEL_ENABLED=  # ⏳ falta · 'true' = cancela en OTASync al procesar el reembolso (default OFF)

# ── Escalamiento del bot por LLAMADA — Twilio voz (25-jun) ───────────────────
# Cuando el bot marca un caso URGENTE, llama por teléfono al responsable. Se usa
# un número de VOZ de Twilio APARTE (no se toca el WhatsApp del hotel). El backend
# ya está construido y gated; solo falta cargar estas credenciales en pre-producción
# y prender el flag. Si no se llama (apagado/sin creds/falla) cae a alerta por correo.
# El flag también es gestionable desde /admin → Configuración.
TWILIO_ACCOUNT_SID=          # ⏳ falta · SID de la cuenta Twilio  ← LO LLENAS TÚ
TWILIO_AUTH_TOKEN=           # ⏳ falta · Auth Token de Twilio (SECRETO)  ← LO LLENAS TÚ
TWILIO_VOICE_NUMBER=         # ⏳ falta · número de voz comprado en Twilio, formato E.164 (ej. +1XXXXXXXXXX)  ← LO LLENAS TÚ
ESCALATION_PHONE_NUMBERS=    # ⏳ falta · números a llamar, E.164 coma-separados — recepción primero, luego dueños (ej. +573218598686,+573057465544,+573163292157). También editable desde /admin → Configuración (no es secreto)
ESCALATION_CALL_ENABLED=     # ⏳ falta · 'true' activa la llamada de escalamiento (default OFF) · también gestionable desde /admin
TWILIO_API_BASE=            # opcional · default https://api.twilio.com
TWILIO_TIMEOUT_MS=          # opcional · default 10000

# ── 2026-07-01 · Facturación Numera + SIRE/TRA + documentos legales ──
# Andamiaje construido y APAGADO. Todo mock-safe: sin credenciales / con el flag
# en OFF, nada llama a la red ni emite/reporta. Encender solo tras validar cada
# integración con su proveedor. Los flags *_ENABLED también son gestionables desde
# /admin → Configuración (override sin redeploy); los SECRETOS viven solo aquí/Netlify.

# Facturación electrónica DIAN vía Numera (hoy en DRY-RUN: arma y valida el
# payload, NO emite). Encender con NUMERA_INVOICING_ENABLED='true' tras confirmar
# el mapeo de la respuesta del proveedor (ver TODO(NUMERA) en _numera.js).
NUMERA_USERNAME=            # ⏳ falta · usuario de Numera  ← LO LLENAS TÚ
NUMERA_PASSWORD=            # ⏳ falta · contraseña de Numera (SECRETO)  ← LO LLENAS TÚ
NUMERA_COMPANY_ID=          # ⏳ falta · id de la empresa/emisor en Numera  ← LO LLENAS TÚ
NUMERA_INVOICING_ENABLED=   # ⏳ falta · 'true' emite de verdad ante la DIAN (default OFF → borrador/DRY-RUN) · también gestionable desde /admin
NUMERA_API_BASE=            # opcional · default https://esnumera.com/api/v1

# TRA — Registro Nacional de Turismo (MinCIT/SIAT). Reporta TODAS las estadías
# (nacionales y extranjeros). Tiene API REST. Confirmar campos con el MinCIT
# (soportesiat@mincit.gov.co) antes de encender (ver TODO(TRA) en _tra.js).
TRA_ENABLED=                # ⏳ falta · 'true' activa el reporte al TRA (default OFF → mock) · también gestionable desde /admin
TRA_TOKEN=                  # ⏳ falta · token del RNT (SECRETO) — se pide en <base>/token/ y llega al correo del RNT  ← LO LLENAS TÚ
TRA_RNT=276306              # número de RNT del establecimiento (MIRADA SAS)
TRA_NIT=902032515-0         # NIT de MIRADA SAS (tomado del RNT)
TRA_API_BASE=               # opcional · default https://traapi.mincit.gov.co/api (la base de acompañantes se deriva → /apitwo)

# SIRE — Migración Colombia (solo extranjeros). NO tiene API: se genera un archivo
# plano (.txt) que una persona sube al portal. Confirmar formato/columnas con el
# portal antes de encender (ver TODO(SIRE) en _sire.js). Ningún valor aquí es secreto.
SIRE_ENABLED=               # ⏳ falta · 'true' habilita la generación del archivo SIRE (default OFF; la generación pura funciona igual para previsualizar) · también gestionable desde /admin
SIRE_HOTEL_CODE=            # ⏳ falta · código de establecimiento asignado por Migración  ← LO LLENAS TÚ
SIRE_CITY_CODE=             # ⏳ falta · código DANE/Migración de la ciudad del hotel (Manizales)  ← LO LLENAS TÚ
SIRE_HOTEL_ADDRESS=         # opcional · dirección del establecimiento (por si el portal la pide)
SIRE_DELIMITER=             # opcional · separador de columnas (default TAB '\t'; acepta la secuencia literal "\t")

# Registro de documentos legales de la empresa (RUT, RNT, Cámara de Comercio,
# certificaciones bancarias) con alertas de vigencia. Lee una carpeta de Google
# Drive (reusa las credenciales de Drive ya cargadas). Nada aquí es secreto.
LEGAL_DOCS_ENABLED=         # ⏳ falta · 'true' activa el listado real desde Drive (default OFF → mock/vacío) · también gestionable desde /admin
LEGAL_DOCS_DRIVE_FOLDER_ID=1uo3ozZVsQN5xXqnziA4PXW7tr5ZNwcMQ  # carpeta de Drive con los PDF legales
LEGAL_DOCS_REQUEST_CONTACT=+573218598686 # a quién solicitar un documento actualizado (aparece en la alerta). Por ahora el número de gerencia / primer número de escalamiento. También gestionable desde /admin
